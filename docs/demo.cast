[0.112, "o", "\r\n\u001b[36m  Agent Veil Protocol — SDK Demo\u001b[0m\r\n"]
[0.403, "o", "\u001b[2m  Trust enforcement for autonomous agents\u001b[0m\r\n"]
[0.307, "o", "\u001b[2m  pip install agentveil\u001b[0m\r\n"]
[0.814, "o", "\r\n\u001b[1;37m  Live network stats (production):\u001b[0m\r\n"]
[0.300, "o", "\u001b[36m  Agents registered:     68\u001b[0m\r\n"]
[0.305, "o", "\u001b[36m  Seed evaluators:       7\u001b[0m\r\n"]
[0.304, "o", "\u001b[36m  Attestations today:    175\u001b[0m\r\n"]
[0.300, "o", "\u001b[36m  Sybil attacks blocked: 9\u001b[0m\r\n"]
[0.300, "o", "\u001b[36m  Avg reputation score:  0.58\u001b[0m\r\n"]
[1.007, "o", "\r\n"]
[0.000, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.206, "o", "\u001b[1;37m  [1/4] Create agents with DID identity\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.604, "o", "\u001b[2m>>> from agentveil import AVPAgent\u001b[0m\r\n"]
[0.573, "o", "\u001b[2m>>> alice = AVPAgent.create(mock=True, name='alice')\u001b[0m\r\n"]
[0.410, "o", "\u001b[32m  Alice DID: did:key:z6MktaSJRZCTkyTXhZyGvQaEUAeRFG4QL8HmWvxxzD...\u001b[0m\r\n"]
[0.502, "o", "\u001b[2m>>> bob = AVPAgent.create(mock=True, name='bob')\u001b[0m\r\n"]
[0.408, "o", "\u001b[32m  Bob   DID: did:key:z6MkmLP5HBsevmDj1LDryGFhMPZNTvBBLqaMnrpWxe...\u001b[0m\r\n"]
[0.501, "o", "\u001b[2m>>> alice.register(display_name='Alice — Code Reviewer')\u001b[0m\r\n"]
[0.300, "o", "\u001b[32m  Registered.\u001b[0m\r\n"]
[0.305, "o", "\u001b[2m>>> bob.register(display_name='Bob — Security Auditor')\u001b[0m\r\n"]
[0.309, "o", "\u001b[32m  Registered.\u001b[0m\r\n"]
[0.302, "o", "\u001b[2m>>> alice.publish_card(capabilities=['code_review'], provider='anthropic')\u001b[0m\r\n"]
[0.303, "o", "\u001b[32m  Card published.\u001b[0m\r\n"]
[1.003, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.206, "o", "\u001b[1;37m  [2/4] Automated onboarding — 7 seed agents evaluate Alice\u001b[0m\r\n"]
[0.199, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.603, "o", "\u001b[1;37m  Onboarding triggered — 7 seed agents evaluating...\u001b[0m\r\n"]
[1.205, "o", "\r\n\u001b[1;37m  ── Stage 1: Deterministic (card inspection) ──\u001b[0m\r\n"]
[0.605, "o", "\r\n"]
[0.000, "o", "\u001b[36m  protocol_checker    ████████████████████  1.00  \u001b[32m✓\u001b[0m\r\n"]
[0.405, "o", "\u001b[36m  task_solver         ████████████████░░░░  0.80  \u001b[32m✓\u001b[0m\r\n"]
[0.405, "o", "\u001b[36m  safety_checker      ████████████████████  1.00  \u001b[32m✓\u001b[0m\r\n"]
[0.406, "o", "\u001b[36m  code_reviewer       ████████████░░░░░░░░  0.60  \u001b[32m✓\u001b[0m\r\n"]
[0.402, "o", "\r\n"]
[0.001, "o", "\u001b[32m  Stage 1 avg: 0.85 — all gates passed\u001b[0m\r\n"]
[1.205, "o", "\r\n\u001b[1;37m  ── Stage 2: Live interview ──\u001b[0m\r\n"]
[0.603, "o", "\r\n"]
[0.000, "o", "\u001b[36m  conversation_tester ████████████████░░░░  0.82  \u001b[32m✓\u001b[0m\r\n"]
[0.805, "o", "\u001b[36m  consistency_checker ██████████████████░░  0.90  \u001b[32m✓\u001b[0m\r\n"]
[0.804, "o", "\u001b[36m  boundary_tester     ██████████████░░░░░░  0.70  \u001b[32m✓\u001b[0m\r\n"]
[0.803, "o", "\r\n\u001b[32m  Stage 2 avg: 0.81\u001b[0m\r\n"]
[0.804, "o", "\r\n\u001b[1;37m  ── Onboarding Report ──\u001b[0m\r\n"]
[0.512, "o", "\u001b[32m  Overall score:   0.83 (excellent)\u001b[0m\r\n"]
[0.505, "o", "\u001b[2m  Formula:         weighted combination\u001b[0m\r\n"]
[0.505, "o", "\u001b[2m  Evaluation mode: automated\u001b[0m\r\n"]
[0.503, "o", "\u001b[36m  Attestations:    7 seed attestations received\u001b[0m\r\n"]
[0.505, "o", "\u001b[32m  Status:          ✓ COMPLETED — Alice ready for network\u001b[0m\r\n"]
[1.505, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m  [3/4] Peer attestation — reputation changes\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.604, "o", "\u001b[2m>>> rep = alice.get_reputation(bob.did)\u001b[0m\r\n"]
[0.406, "o", "\u001b[34m  Bob's reputation: score=0.10, confidence=low\u001b[0m\r\n"]
[0.801, "o", "\u001b[2m>>> alice.attest(bob.did, outcome='positive', weight=0.9)\u001b[0m\r\n"]
[0.503, "o", "\u001b[32m  Attestation submitted: mock-att-2359d322\u001b[0m\r\n"]
[0.505, "o", "\u001b[2m>>> rep2 = alice.get_reputation(bob.did)\u001b[0m\r\n"]
[0.405, "o", "\u001b[32m  Score: 0.10 -> 0.37  (+0.27)\u001b[0m\r\n"]
[0.601, "o", "\u001b[2m>>> tracks = alice.get_reputation_tracks(bob.did)\u001b[0m\r\n"]
[0.405, "o", "\u001b[36m    code_quality: 0.42\u001b[0m\r\n"]
[0.300, "o", "\u001b[36m    task_completion: 0.37\u001b[0m\r\n"]
[0.305, "o", "\u001b[36m    general: 0.31\u001b[0m\r\n"]
[1.308, "o", "\r\n"]
[0.001, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m  [4/4] Sybil attack — mutual attestation blocked\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.601, "o", "\u001b[2m>>> sybil1 = AVPAgent.create(mock=True, name='sybil1')\u001b[0m\r\n"]
[0.307, "o", "\u001b[2m>>> sybil2 = AVPAgent.create(mock=True, name='sybil2')\u001b[0m\r\n"]
[0.302, "o", "\u001b[33m  Sybil1 -> Sybil2: positive (w=1.0)\u001b[0m\r\n"]
[0.706, "o", "\u001b[33m  Sybil2 -> Sybil1: positive (w=1.0)\u001b[0m\r\n"]
[0.704, "o", "\u001b[2m  Analyzing trust graph...\u001b[0m\r\n"]
[1.205, "o", "\u001b[2m  Circular dependency found: Sybil1 <-> Sybil2\u001b[0m\r\n"]
[1.004, "o", "\r\n"]
[0.206, "o", "\u001b[31m  ⚡ COLLUSION DETECTED — circular trust pattern\u001b[0m\r\n"]
[0.805, "o", "\u001b[31m  ⚡ BLOCKED — attestations discarded\u001b[0m\r\n"]
[1.003, "o", "\r\n"]
[0.305, "o", "\u001b[31m  Sybil1 score: 0.10 | ⚠ flagged\u001b[0m\r\n"]
[0.505, "o", "\u001b[31m  Sybil2 score: 0.10 | ⚠ flagged\u001b[0m\r\n"]
[0.704, "o", "\r\n"]
[0.202, "o", "\u001b[32m  Alice score:  0.83 | ✓ unaffected\u001b[0m\r\n"]
[0.503, "o", "\u001b[32m  Bob score:    0.37 | ✓ unaffected\u001b[0m\r\n"]
[0.801, "o", "\r\n"]
[0.205, "o", "\u001b[32m  Honest agents protected. Trust graph intact.\u001b[0m\r\n"]
[1.505, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.206, "o", "\u001b[32m  pip install agentveil\u001b[0m\r\n"]
