{"version":3,"term":{"cols":80,"rows":24},"timestamp":1774903249,"command":"python3 examples/demo_gif.py","env":{"SHELL":"/bin/zsh"}}
[0.074, "o", "\r\n\u001b[36m  Agent Veil Protocol — SDK Demo\u001b[0m\r\n"]
[0.405, "o", "\u001b[2m  Trust & identity layer for AI agents\u001b[0m\r\n"]
[0.305, "o", "\u001b[2m  pip install agentveil\u001b[0m\r\n"]
[0.805, "o", "\r\n\u001b[1;37m  Live network stats (production):\u001b[0m\r\n"]
[0.305, "o", "\u001b[36m  Agents registered:     61\u001b[0m\r\n"]
[0.302, "o", "\u001b[36m  Attestations today:    175\u001b[0m\r\n"]
[0.305, "o", "\u001b[36m  Sybil attacks blocked: 9\u001b[0m\r\n"]
[0.305, "o", "\u001b[36m  Avg reputation score:  0.58\u001b[0m\r\n"]
[1.005, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.201, "o", "\u001b[1;37m  [1/3] Create agents with DID identity\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.601, "o", "\u001b[2m>>> from agentveil import AVPAgent\u001b[0m\r\n"]
[0.557, "o", "\u001b[2m>>> alice = AVPAgent.create(mock=True, name='alice')\u001b[0m\r\n"]
[0.407, "o", "\u001b[32m  Alice DID: did:key:z6Mkjji3MfqNkkmeGxA7YxSqg2zB9d81kc3njx5TVN...\u001b[0m\r\n"]
[0.503, "o", "\u001b[2m>>> bob = AVPAgent.create(mock=True, name='bob')\u001b[0m\r\n"]
[0.406, "o", "\u001b[32m  Bob   DID: did:key:z6Mkpvnn4QV72fGayY2fuytW3XJnJKnEAsuVCvR6ps...\u001b[0m\r\n"]
[0.505, "o", "\u001b[2m>>> alice.register(display_name='Alice — Code Reviewer')\u001b[0m\r\n"]
[0.301, "o", "\u001b[32m  Registered.\u001b[0m\r\n"]
[0.306, "o", "\u001b[2m>>> bob.register(display_name='Bob — Security Auditor')\u001b[0m\r\n"]
[0.301, "o", "\u001b[32m  Registered.\u001b[0m\r\n"]
[0.305, "o", "\u001b[2m>>> alice.publish_card(capabilities=['code_review'], provider='anthropic')\u001b[0m\r\n"]
[0.305, "o", "\u001b[32m  Card published.\u001b[0m\r\n"]
[1.005, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m  [2/3] Peer attestation — reputation changes\u001b[0m\r\n"]
[0.203, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.605, "o", "\u001b[2m>>> rep = alice.get_reputation(bob.did)\u001b[0m\r\n"]
[0.402, "o", "\u001b[34m  Bob's reputation: score=0.75, confidence=0.1\u001b[0m\r\n"]
[0.805, "o", "\u001b[2m>>> alice.attest(bob.did, outcome='positive', weight=0.9)\u001b[0m\r\n"]
[0.505, "o", "\u001b[32m  Attestation submitted: mock-att-0c999dc9\u001b[0m\r\n"]
[0.505, "o", "\u001b[2m>>> rep2 = alice.get_reputation(bob.did)\u001b[0m\r\n"]
[0.403, "o", "\u001b[32m  Score: 0.75 -> 0.768  (+0.018)\u001b[0m\r\n"]
[0.601, "o", "\u001b[2m>>> tracks = alice.get_reputation_tracks(bob.did)\u001b[0m\r\n"]
[0.402, "o", "\u001b[36m    code_quality: 0.818\u001b[0m\r\n"]
[0.302, "o", "\u001b[36m    task_completion: 0.768\u001b[0m\r\n"]
[0.303, "o", "\u001b[36m    data_accuracy: 0.738\u001b[0m\r\n"]
[1.308, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.203, "o", "\u001b[1;37m  [3/3] Sybil attack — mutual attestation blocked\u001b[0m\r\n"]
[0.204, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.603, "o", "\u001b[2m>>> sybil1 = AVPAgent.create(mock=True, name='sybil1')\u001b[0m\r\n"]
[0.301, "o", "\u001b[2m>>> sybil2 = AVPAgent.create(mock=True, name='sybil2')\u001b[0m\r\n"]
[0.306, "o", "\u001b[33m  Sybil1 -> Sybil2: positive (w=1.0)\u001b[0m\r\n"]
[0.700, "o", "\u001b[33m  Sybil2 -> Sybil1: positive (w=1.0)\u001b[0m\r\n"]
[0.705, "o", "\u001b[2m  Analyzing trust graph...\u001b[0m\r\n"]
[1.203, "o", "\u001b[2m  Circular dependency found: Sybil1 <-> Sybil2\u001b[0m\r\n"]
[1.004, "o", "\r\n"]
[0.204, "o", "\u001b[31m  ⚡ COLLUSION DETECTED — circular trust pattern\u001b[0m\r\n"]
[0.803, "o", "\u001b[31m  ⚡ BLOCKED — attestations discarded\u001b[0m\r\n"]
[1.005, "o", "\r\n"]
[0.301, "o", "\u001b[31m  Sybil1 score: 0.10 | ⚠ flagged\u001b[0m\r\n"]
[0.503, "o", "\u001b[31m  Sybil2 score: 0.10 | ⚠ flagged\u001b[0m\r\n"]
[0.705, "o", "\r\n"]
[0.205, "o", "\u001b[32m  Alice score:  0.77 | ✓ unaffected\u001b[0m\r\n"]
[0.504, "o", "\u001b[32m  Bob score:    0.77 | ✓ unaffected\u001b[0m\r\n"]
[0.806, "o", "\r\n"]
[0.204, "o", "\u001b[32m  Honest agents protected. Trust graph intact.\u001b[0m\r\n"]
[1.505, "o", "\r\n\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.201, "o", "\u001b[32m  pip install agentveil\u001b[0m\r\n"]
[0.309, "o", "\u001b[32m  https://github.com/creatorrmode-lead/avp-sdk\u001b[0m\r\n"]
[0.305, "o", "\u001b[1;37m========================================================\u001b[0m\r\n"]
[0.502, "o", "\r\n"]
